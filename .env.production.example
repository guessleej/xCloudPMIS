# ════════════════════════════════════════════════════════════
# xCloudPMIS — Production 環境變數範本
# ════════════════════════════════════════════════════════════
# 使用方式：
#   cp .env.production.example .env
#   vim .env   # 填入真實值
#
# ⚠️  .env 絕對不能提交到 Git！
# ════════════════════════════════════════════════════════════

# ── 應用程式版本 ─────────────────────────────────────────────
APP_VERSION=1.0.0
NODE_ENV=production

# ── 對外網址（用於 OAuth callback、Email 連結）─────────────
APP_URL=https://pmis.your-domain.com
VITE_API_URL=/api
VITE_WS_URL=wss://pmis.your-domain.com/collab

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=pmis-db
DB_PORT=5432
DB_NAME=pmis_db
DB_USER=pmis_user
# 使用至少 32 字元的隨機密碼
DB_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://pmis_user:CHANGE_ME_strong_password_here@pmis-db:5432/pmis_db

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=pmis-redis
REDIS_PORT=6379
# 使用至少 32 字元的隨機密碼
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── JWT ─────────────────────────────────────────────────────
# 使用 openssl rand -hex 64 生成
JWT_SECRET=CHANGE_ME_jwt_secret_64chars_minimum_here
JWT_EXPIRES_IN=24h

# ── Microsoft 365 OAuth（可選，用於 Outlook 整合）─────────
O365_CLIENT_ID=your-azure-app-client-id
O365_CLIENT_SECRET=your-azure-app-client-secret
O365_TENANT_ID=your-azure-tenant-id
O365_REDIRECT_URI=https://pmis.your-domain.com/auth/microsoft/callback

# ── OpenAI（AI 決策中心）──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
AI_LANGUAGE=zh-TW
AI_MAX_TOKENS=4000

# ── 公司設定 ────────────────────────────────────────────────
COMPANY_NAME=您的公司名稱
COMPANY_ID=1

# ── 排程設定 ────────────────────────────────────────────────
# 風險掃描頻率（預設：每天早上 8:00）
MONITOR_CRON=0 8 * * *
TZ=Asia/Taipei

# ── Email 設定 ──────────────────────────────────────────────
EMAIL_DOMAIN_WHITELIST=your-domain.com
EMAIL_BATCH_DELAY_MS=500

# ── 安全性 ──────────────────────────────────────────────────
# 允許的前端來源（CORS）
ALLOWED_ORIGINS=https://pmis.your-domain.com
