// ============================================================
// Prisma Schema — xCloudPMIS v2.0（Phase 3 進階功能）
//
// 變更說明（Phase 3 新增）：
//   - task_dependencies：任務依賴關係
//   - milestones：專案里程碑
//   - time_entries：工時計時記錄
//   - attachments：任務檔案附件
//   - comments：任務評論（支援回覆串）
//   - tags + task_tags：彩色標籤（多對多）
//   - notifications：使用者通知
//   - activity_logs：任務變更歷史
//
//   既有表格修改：
//   - Task：新增 actualHours、startedAt、completedAt
// ============================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ════════════════════════════════════════════════════════════
// 既有模型（Phase 1，此次有修改的部分）
// ════════════════════════════════════════════════════════════

model Company {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  projects      Project[]
  workspaces    Workspace[]
  automationRules AutomationRule[]
  automationRuleRuns AutomationRuleRun[]
  tags          Tag[]           // ← Phase 3 新增：公司共用標籤庫
  aiModelConfig AiModelConfig[] // ← Phase 4 新增：AI 模型設定
  goals         Goal[]          // ← Phase 5 新增：OKR 目標管理
  workflows     Workflow[]      // ← Phase 6 新增：工作流程
  forms         Form[]          // ← Phase 6 新增：表單管理
  formSubmissions FormSubmission[] // ← 表單提交紀錄
  portfolios    Portfolio[]     // ← 專案組合
  customFields  CustomFieldDefinition[] @relation("CompanyCustomFields") // ← Phase 6
  workTimeLogs  WorkTimeLog[]           // ← 手動工時記錄（每日時間表）
  aiSuggestions AiSuggestion[]          // ← AI 建議決策

  @@map("companies")
}

model User {
  id           Int       @id @default(autoincrement())
  companyId    Int       @map("company_id")
  name         String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  role         Role      @default(member)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // ── 個人資料擴充 ──────────────────────────────────────
  department  String?   @db.VarChar(100)          // 部門
  phone       String?   @db.VarChar(50)            // 電話
  jobTitle    String?   @map("job_title") @db.VarChar(100) // 職稱
  joinedAt    DateTime? @map("joined_at") @db.Date // 加入日期
  settings    Json?     @map("settings_json")      // 個人偏好（通知、介面設定）

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownedProjects Project[]     @relation("ProjectOwner")
  createdProjects Project[]   @relation("ProjectCreator")
  assignedTasks Task[]         @relation("TaskAssignee")
  createdTasks  Task[]         @relation("TaskCreator")
  createdWorkspaces Workspace[] @relation("WorkspaceCreator")
  workspaceMemberships WorkspaceMember[]
  createdTeams Team[] @relation("TeamCreator")
  teamMemberships TeamMember[]
  projectMemberships ProjectMember[]
  taskAssigneeLinks TaskAssigneeLink[] @relation("TaskAssigneeLinkUser")
  taskAssigneeAssignedBy TaskAssigneeLink[] @relation("TaskAssigneeLinkAssignedBy")
  taskProjectAdded TaskProject[] @relation("TaskProjectAddedBy")
  customFieldDefinitions CustomFieldDefinition[] @relation("CustomFieldCreator")
  customFieldUserValues CustomFieldValue[] @relation("CustomFieldUserValue")
  automationRulesCreated AutomationRule[] @relation("AutomationRuleCreator")
  automationRulesUpdated AutomationRule[] @relation("AutomationRuleUpdater")
  automationRuleRunsTriggered AutomationRuleRun[] @relation("AutomationRuleTriggeredBy")

  // ── Phase 3 新增的關聯 ────────────────────────────────
  timeEntries   TimeEntry[]    // 這個人的所有工時記錄（計時器）
  workTimeLogs  WorkTimeLog[]  // 這個人的手動工時記錄
  attachments   Attachment[]   // 這個人上傳的所有附件
  comments      Comment[]      // 這個人發的所有評論
  notifications Notification[] // 這個人收到的所有通知
  activityLogs  ActivityLog[]  // 這個人造成的所有變更記錄

  // ── OAuth 整合 ────────────────────────────────────────
  oauthToken    OAuthToken?    // Microsoft 365 Delegated 授權 Token（每人最多一個）

  @@index([companyId])
  @@index([email])
  @@map("users")
}

enum Role {
  admin
  pm
  member
}

enum WorkspaceVisibility {
  company
  private
}

enum WorkspaceMemberRole {
  admin
  member
  guest
}

enum TeamPrivacy {
  open
  closed
  private
}

enum TeamMemberRole {
  lead
  member
  guest
}

enum ProjectAccess {
  public   // 對工作空間所有成員公開
  team     // 僅專案成員可見（預設）
  private  // 僅建立者可見
}

enum ProjectMemberRole {
  owner
  editor
  commenter
  viewer
}

enum CustomFieldScope {
  workspace
  team
  project
}

enum CustomFieldEntityType {
  task
  project
}

enum CustomFieldType {
  text
  number
  currency
  percent
  checkbox
  date
  datetime
  single_select
  multi_select
  people
}

model Project {
  id          Int           @id @default(autoincrement())
  companyId   Int           @map("company_id")
  workspaceId Int?          @map("workspace_id")
  teamId      Int?          @map("team_id")
  ownerId     Int?          @map("owner_id")
  createdById Int?          @map("created_by_id")
  name        String        @db.VarChar(255)
  description String        @default("")
  status      ProjectStatus @default(active)
  access      ProjectAccess @default(team)
  budget      Decimal?      @db.Decimal(15, 2)
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  archivedAt  DateTime?     @map("archived_at")
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspace  Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  team       Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  owner      User?       @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy  User?       @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tasks      Task[]
  taskProjects TaskProject[]
  automationRuleScopes AutomationRuleProject[]
  automationRuleRuns AutomationRuleRun[]
  members    ProjectMember[]
  customFieldLinks ProjectCustomField[]
  customFieldValues CustomFieldValue[] @relation("ProjectCustomFieldValues")
  milestones Milestone[] // ← Phase 3 新增：里程碑
  aiDecisions AiDecision[] // ← AI 自主代理決策記錄
  portfolioLinks PortfolioProject[] // ← 所屬組合

  @@index([companyId])
  @@index([workspaceId])
  @@index([teamId])
  @@index([ownerId])
  @@index([createdById])
  @@index([status])
  @@index([deletedAt])
  @@map("projects")
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
  cancelled
  archived
}

enum AutomationRuleTriggerType {
  task_created
  task_completed
  due_date_approaching
  status_changed
  assignee_changed
  field_changed
}

enum AutomationRuleRunStatus {
  success
  skipped
  failed
}

model AutomationRule {
  id              Int                       @id @default(autoincrement())
  companyId       Int                       @map("company_id")
  createdById     Int?                      @map("created_by_id")
  updatedById     Int?                      @map("updated_by_id")
  ruleKey         String                    @default(cuid()) @map("rule_key") @db.VarChar(120)
  name            String                    @db.VarChar(255)
  description     String                    @default("")
  isEnabled       Boolean                   @default(true) @map("is_enabled")
  isSystem        Boolean                   @default(false) @map("is_system")
  triggerType     AutomationRuleTriggerType @map("trigger_type")
  triggerConfig   Json?                     @map("trigger_config")
  conditions      Json?
  actions         Json?
  triggerCount    Int                       @default(0) @map("trigger_count")
  lastTriggeredAt DateTime?                 @map("last_triggered_at")
  deletedAt       DateTime?                 @map("deleted_at")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("AutomationRuleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?   @relation("AutomationRuleUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  projectScopes AutomationRuleProject[]
  runs          AutomationRuleRun[]

  @@unique([companyId, ruleKey])
  @@index([companyId, isEnabled])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedAt])
  @@map("automation_rules")
}

model AutomationRuleProject {
  ruleId     Int      @map("rule_id")
  projectId  Int      @map("project_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  rule    AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([ruleId, projectId])
  @@index([projectId])
  @@map("automation_rule_projects")
}

model AutomationRuleRun {
  id            Int                     @id @default(autoincrement())
  ruleId         Int                     @map("rule_id")
  companyId      Int                     @map("company_id")
  projectId      Int?                    @map("project_id")
  taskId         Int?                    @map("task_id")
  triggeredById  Int?                    @map("triggered_by_id")
  status         AutomationRuleRunStatus @default(success)
  context        Json?
  result         Json?
  createdAt      DateTime                @default(now()) @map("created_at")

  rule        AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task        Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  triggeredBy User?          @relation("AutomationRuleTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([ruleId, createdAt])
  @@index([companyId, createdAt])
  @@index([projectId])
  @@index([taskId])
  @@index([triggeredById])
  @@map("automation_rule_runs")
}

// ── 任務表（Phase 3 新增三個欄位 + 多個新關聯）─────────────
model Task {
  id             Int        @id @default(autoincrement())
  projectId      Int        @map("project_id")
  assigneeId     Int?       @map("assignee_id")
  createdById    Int?       @map("created_by")
  parentTaskId   Int?       @map("parent_task_id")
  title          String     @db.VarChar(500)
  description    String     @default("")
  status         TaskStatus @default(todo)
  priority       Priority   @default(medium)
  estimatedHours Decimal?   @map("estimated_hours") @db.Decimal(6, 2)

  // ── Phase 3 新增欄位 ──────────────────────────────────
  /// 實際花費工時（從 time_entries 匯總，方便快速查詢不用每次計算）
  actualHours    Decimal?   @map("actual_hours") @db.Decimal(6, 2)
  /// 用於顯示父任務/大型任務的完成進度條（0~100）
  progressPercent Int       @default(0) @map("progress_percent")
  /// 任務實際開始時間（第一次把狀態改為 in_progress 的時間）
  startedAt      DateTime?  @map("started_at")
  /// 任務實際完成時間（把狀態改為 done 的時間）
  completedAt    DateTime?  @map("completed_at")
  // ─────────────────────────────────────────────────────

  dueDate        DateTime?  @map("due_date") @db.Date
  /// 截止時間（HH:MM 格式，如 "09:00"、"17:30"），搭配 dueDate 使用
  dueTime        String?    @map("due_time") @db.VarChar(5)
  /// 計劃開始時間（甘特圖用）
  planStart      DateTime?  @map("plan_start") @db.Date
  /// 計劃結束時間（甘特圖用）
  planEnd        DateTime?  @map("plan_end") @db.Date
  /// 健康度：null = 系統自動計算；有值 = 手動覆寫
  healthStatus   HealthStatus? @map("health_status")
  position       Int        @default(0)
  deletedAt      DateTime?  @map("deleted_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User?    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  parentTask   Task?    @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks     Task[]   @relation("TaskSubtasks")
  taskProjects TaskProject[]
  taskAssigneeLinks TaskAssigneeLink[]
  customFieldValues CustomFieldValue[] @relation("TaskCustomFieldValues")

  // ── Phase 3 新增的關聯 ────────────────────────────────
  /// 這個任務「依賴哪些前置任務」（例：Task A 必須先完成，我才能開始）
  dependencies    TaskDependency[] @relation("TaskDependencies")
  /// 「哪些後續任務依賴我」（反向查詢用）
  dependents      TaskDependency[] @relation("TaskDependents")

  timeEntries     TimeEntry[]   // 這個任務上的所有計時記錄
  attachments     Attachment[]  // 這個任務的所有附件
  comments        Comment[]     // 這個任務的所有評論
  activityLogs    ActivityLog[] // 這個任務的所有變更歷史
  taskTags        TaskTag[]     // 這個任務的所有標籤（多對多）
  aiDecisions     AiDecision[]  // ← AI 自主代理決策記錄
  checklistItems  ChecklistItem[] // 任務待辦清單項目
  automationRuleRuns AutomationRuleRun[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([parentTaskId])
  @@index([status])
  @@index([priority])
  @@index([deletedAt])
  @@map("tasks")
}

model Workspace {
  id          Int                 @id @default(autoincrement())
  companyId   Int                 @map("company_id")
  createdById Int?                @map("created_by_id")
  name        String              @db.VarChar(255)
  slug        String              @db.VarChar(100)
  description String              @default("")
  visibility  WorkspaceVisibility @default(company)
  isDefault   Boolean             @default(false) @map("is_default")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: SetNull)

  members                WorkspaceMember[]
  teams                  Team[]
  projects               Project[]
  customFieldDefinitions CustomFieldDefinition[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([createdById])
  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId Int                 @map("workspace_id")
  userId      Int                 @map("user_id")
  role        WorkspaceMemberRole @default(member)
  joinedAt    DateTime            @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model Team {
  id          Int         @id @default(autoincrement())
  workspaceId Int         @map("workspace_id")
  createdById Int?        @map("created_by_id")
  name        String      @db.VarChar(255)
  slug        String      @db.VarChar(100)
  description String      @default("")
  privacy     TeamPrivacy @default(private)
  color       String?     @db.VarChar(20)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("TeamCreator", fields: [createdById], references: [id], onDelete: SetNull)

  members  TeamMember[]
  projects Project[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([createdById])
  @@map("teams")
}

model TeamMember {
  teamId   Int            @map("team_id")
  userId   Int            @map("user_id")
  role     TeamMemberRole @default(member)
  joinedAt DateTime       @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model ProjectMember {
  projectId Int               @map("project_id")
  userId    Int               @map("user_id")
  role      ProjectMemberRole @default(editor)
  joinedAt  DateTime          @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model TaskProject {
  taskId     Int      @map("task_id")
  projectId  Int      @map("project_id")
  addedById  Int?     @map("added_by_id")
  position   Int      @default(0)
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  addedBy User?   @relation("TaskProjectAddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  @@id([taskId, projectId])
  @@index([projectId, position])
  @@index([addedById])
  @@map("task_projects")
}

model TaskAssigneeLink {
  taskId       Int      @map("task_id")
  userId       Int      @map("user_id")
  assignedById Int?     @map("assigned_by_id")
  isPrimary    Boolean  @default(false) @map("is_primary")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  task       Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User  @relation("TaskAssigneeLinkUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("TaskAssigneeLinkAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@id([taskId, userId])
  @@index([userId])
  @@index([assignedById])
  @@map("task_assignees")
}

model ChecklistItem {
  id          Int      @id @default(autoincrement())
  taskId      Int      @map("task_id")
  title       String   @db.VarChar(500)
  isDone      Boolean  @default(false) @map("is_done")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("checklist_items")
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum HealthStatus {
  on_track
  at_risk
  off_track
}

enum Priority {
  low
  medium
  high
  urgent
}

// ════════════════════════════════════════════════════════════
// Phase 3 新增模型
// ════════════════════════════════════════════════════════════

// ── 表格 5：task_dependencies（任務依賴關係）────────────────
//
// 什麼是任務依賴？
//   假設：「部署上線」必須等「測試通過」完成後才能開始
//   這就是：部署上線 depends_on 測試通過（finish_to_start）
//
// 三種依賴類型：
//   finish_to_start  = A 完成後，B 才能開始（最常見）
//   start_to_start   = A 開始後，B 才能開始（同步開始）
//   finish_to_finish = A 完成後，B 才能完成（同步結束）
//
// 循環依賴防護：
//   A→B→C→A 這樣的循環是不允許的！
//   要在應用程式層用 DFS（深度優先搜尋）演算法檢查
//   （詳見 backend/src/utils/dependencyCheck.js）
// ─────────────────────────────────────────────────────────
model TaskDependency {
  id              Int            @id @default(autoincrement())
  taskId          Int            @map("task_id")          // 後置任務（需要等待的那個）
  dependsOnTaskId Int            @map("depends_on_task_id") // 前置任務（必須先做的那個）
  dependencyType  DependencyType @default(finish_to_start) @map("dependency_type")
  createdAt       DateTime       @default(now()) @map("created_at")

  task          Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask Task @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  // 防止同樣的依賴關係被建立兩次
  @@unique([taskId, dependsOnTaskId])
  @@index([taskId])
  @@index([dependsOnTaskId])
  @@map("task_dependencies")
}

enum DependencyType {
  finish_to_start  // 完成才能開始（最常用）
  start_to_start   // 同時開始
  finish_to_finish // 同時完成
}

// ── 表格 6：milestones（里程碑）─────────────────────────────
//
// 什麼是里程碑？
//   專案中的重要檢查點，例如：「Beta 版發布」、「UAT 驗收完成」
//   在甘特圖上顯示為菱形標記（◆）
// ─────────────────────────────────────────────────────────
model Milestone {
  id          Int            @id @default(autoincrement())
  projectId   Int            @map("project_id")
  name        String         @db.VarChar(255)    // 里程碑名稱
  description String         @default("")
  dueDate     DateTime       @map("due_date") @db.Date  // 預定達成日期
  isAchieved  Boolean        @default(false) @map("is_achieved") // 是否已達成
  achievedAt  DateTime?      @map("achieved_at") // 實際達成時間
  color       MilestoneColor @default(green)     // 顏色標籤（紅=延誤風險、黃=注意、綠=正常）
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([dueDate])
  @@map("milestones")
}

enum MilestoneColor {
  red    // 紅色：高風險、已延誤
  yellow // 黃色：需注意
  green  // 綠色：正常進行
}

// ── 表格 7：time_entries（工時計時記錄）─────────────────────
//
// 計時流程：
//   1. 按「開始計時」→ 建立一筆 ended_at = NULL 的記錄
//   2. 按「停止計時」→ 填入 ended_at，計算 duration_minutes
//
// 防止重複計時：
//   同一個 user_id 不能同時有兩筆 ended_at = NULL 的記錄
//   （在應用程式層檢查）
// ─────────────────────────────────────────────────────────
model TimeEntry {
  id              Int       @id @default(autoincrement())
  taskId          Int       @map("task_id")
  userId          Int       @map("user_id")
  startedAt       DateTime  @map("started_at")  // 計時開始時間
  endedAt         DateTime? @map("ended_at")    // 計時結束時間（null = 計時進行中）
  durationMinutes Int?      @map("duration_minutes") // 總時長（分鐘），停止後才填入
  description     String    @default("")        // 工作描述（可以空白）
  date            DateTime  @db.Date            // 記錄日期（方便按日統計）
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([date])           // 常用：統計某日期範圍的工時
  @@index([endedAt])        // 常用：查詢進行中的計時（endedAt IS NULL）
  @@map("time_entries")
}

// ── 表格 8：attachments（任務檔案附件）──────────────────────
//
// 檔案命名策略：
//   originalName = 使用者上傳的原始檔名（如：企劃書.pdf）
//   storedName   = 儲存時用 UUID 重新命名（如：550e8400-e29b-...pdf）
//   好處：避免檔名衝突、避免路徑遍歷攻擊（Path Traversal）
// ─────────────────────────────────────────────────────────
model Attachment {
  id            Int      @id @default(autoincrement())
  taskId        Int      @map("task_id")
  uploadedById  Int      @map("uploaded_by")
  originalName  String   @map("original_name") @db.VarChar(255) // 原始檔名
  storedName    String   @map("stored_name") @db.VarChar(255)   // 儲存檔名（UUID）
  filePath      String   @map("file_path")                       // 完整路徑或 S3 URL
  mimeType      String   @map("mime_type") @db.VarChar(100)     // 例如 image/jpeg、application/pdf
  fileSizeBytes Int      @map("file_size_bytes")                 // 檔案大小（位元組）
  thumbnailPath String?  @map("thumbnail_path")                  // 縮圖路徑（只有圖片才有）
  createdAt     DateTime @default(now()) @map("created_at")

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([uploadedById])
  @@map("attachments")
}

model MyFile {
  id            Int      @id @default(autoincrement())
  userId        Int      @default(4) @map("user_id")
  originalName  String   @map("original_name") @db.VarChar(255)
  storedName    String   @unique @map("stored_name") @db.VarChar(255)
  mimeType      String   @default("") @map("mime_type") @db.VarChar(100)
  fileSizeBytes BigInt   @default(0) @map("file_size_bytes")
  filePath      String   @map("file_path") @db.VarChar(500)
  ext           String   @default("") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("my_files")
}

// ── 表格 9：comments（評論與回覆串）─────────────────────────
//
// 巢狀評論結構：
//   頂層評論：parentId = NULL
//   回覆某評論：parentId = 那則評論的 ID
//   注意：只支援一層回覆（不支援無限巢狀，Asana 也是這樣）
//
// @提及功能：
//   mentions 欄位儲存被提及的 user IDs 陣列
//   例如：[2, 5] 代表提及了 ID 為 2 和 5 的使用者
//   同時會在 notifications 表建立通知記錄
// ─────────────────────────────────────────────────────────
model Comment {
  id        Int       @id @default(autoincrement())
  taskId    Int       @map("task_id")
  userId    Int       @map("user_id")    // 留言的人
  parentId  Int?      @map("parent_id") // 回覆哪則留言（null = 頂層留言）
  content   String    @db.Text          // 留言內容
  /// 被提及的使用者 ID 陣列，例如 [2, 5]
  /// 儲存格式：PostgreSQL JSONB（可以索引、可以查詢）
  mentions  Json      @default("[]")
  isEdited  Boolean   @default(false) @map("is_edited")  // 是否已被編輯過
  editedAt  DateTime? @map("edited_at")                  // 最後編輯時間
  deletedAt DateTime? @map("deleted_at")                 // 軟刪除
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  task    Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies Comment[] @relation("CommentReplies") // 這則留言的所有回覆

  @@index([taskId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

// ── 表格 10：tags（標籤）────────────────────────────────────
//
// 每間公司有自己的標籤庫
// 標籤和任務是多對多關係（一個任務可以有多個標籤，一個標籤可以用在多個任務）
// ─────────────────────────────────────────────────────────
model Tag {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  name      String   @db.VarChar(50)          // 標籤名稱，例如「Bug」、「功能需求」
  color     String   @default("#6b7280") @db.VarChar(20) // 十六進位顏色碼，例如 #ef4444

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  taskTags TaskTag[]

  @@unique([companyId, name])   // 同一公司內標籤名稱不能重複
  @@index([companyId])
  @@map("tags")
}

// ── 表格 11：task_tags（任務-標籤 多對多中間表）─────────────
model TaskTag {
  taskId    Int      @map("task_id")
  tagId     Int      @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])  // 複合主鍵：一個任務不能有兩個相同標籤
  @@map("task_tags")
}

model CustomFieldDefinition {
  id           Int                   @id @default(autoincrement())
  companyId    Int?                  @map("company_id")         // ← Phase 6 新增
  workspaceId  Int?                  @map("workspace_id")
  createdById  Int?                  @map("created_by_id")
  name         String                @db.VarChar(255)
  description  String                @default("")
  fieldType    CustomFieldType       @map("field_type")
  entityType   CustomFieldEntityType @default(task) @map("entity_type")
  scope        CustomFieldScope      @default(project)
  isRequired   Boolean               @default(false) @map("is_required")
  isArchived   Boolean               @default(false) @map("is_archived")
  sortOrder    Int                   @default(0) @map("sort_order")
  currencyCode String?               @map("currency_code") @db.VarChar(3)
  settings     Json?                 @map("settings_json")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  company   Company?   @relation("CompanyCustomFields", fields: [companyId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  createdBy User?      @relation("CustomFieldCreator", fields: [createdById], references: [id], onDelete: SetNull)

  options  CustomFieldOption[]
  projects ProjectCustomField[]
  values   CustomFieldValue[]

  @@index([companyId])
  @@index([workspaceId, entityType])
  @@index([createdById])
  @@index([scope])
  @@map("custom_field_definitions")
}

model CustomFieldOption {
  id           Int      @id @default(autoincrement())
  definitionId Int      @map("definition_id")
  name         String   @db.VarChar(255)
  color        String?  @db.VarChar(20)
  sortOrder    Int      @default(0) @map("sort_order")
  isArchived   Boolean  @default(false) @map("is_archived")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  definition         CustomFieldDefinition  @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  singleSelectValues CustomFieldValue[]     @relation("SingleSelectOptionValue")
  multiSelectValues  CustomFieldValueOption[]

  @@unique([definitionId, name])
  @@index([definitionId, sortOrder])
  @@map("custom_field_options")
}

model ProjectCustomField {
  projectId    Int      @map("project_id")
  definitionId Int      @map("definition_id")
  isPinned     Boolean  @default(false) @map("is_pinned")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  project    Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@id([projectId, definitionId])
  @@index([definitionId])
  @@map("project_custom_fields")
}

model CustomFieldValue {
  id            Int       @id @default(autoincrement())
  definitionId  Int       @map("definition_id")
  taskId        Int?      @map("task_id")
  projectId     Int?      @map("project_id")
  textValue     String?   @map("text_value") @db.Text
  numberValue   Decimal?  @map("number_value") @db.Decimal(18, 4)
  booleanValue  Boolean?  @map("boolean_value")
  dateValue     DateTime? @map("date_value") @db.Date
  dateTimeValue DateTime? @map("datetime_value")
  userValueId   Int?      @map("user_value_id")
  optionValueId Int?      @map("option_value_id")
  jsonValue     Json?     @map("json_value")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  definition  CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  task        Task?                 @relation("TaskCustomFieldValues", fields: [taskId], references: [id], onDelete: Cascade)
  project     Project?              @relation("ProjectCustomFieldValues", fields: [projectId], references: [id], onDelete: Cascade)
  userValue   User?                 @relation("CustomFieldUserValue", fields: [userValueId], references: [id], onDelete: SetNull)
  optionValue CustomFieldOption?    @relation("SingleSelectOptionValue", fields: [optionValueId], references: [id], onDelete: SetNull)

  multiSelectOptions CustomFieldValueOption[]

  @@unique([definitionId, taskId])
  @@unique([definitionId, projectId])
  @@index([taskId])
  @@index([projectId])
  @@index([userValueId])
  @@index([optionValueId])
  @@map("custom_field_values")
}

model CustomFieldValueOption {
  valueId   Int      @map("value_id")
  optionId  Int      @map("option_id")
  createdAt DateTime @default(now()) @map("created_at")

  value  CustomFieldValue  @relation(fields: [valueId], references: [id], onDelete: Cascade)
  option CustomFieldOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([valueId, optionId])
  @@index([optionId])
  @@map("custom_field_value_options")
}

// ── 表格 12：notifications（使用者通知）─────────────────────
//
// 何時產生通知？
//   task_assigned       → 某任務被指派給你
//   deadline_approaching → 任務 24 小時內到期（排程任務觸發）
//   mentioned           → 評論中被 @提及
//   comment_added       → 你的任務有新評論
//   task_completed      → 你指派的任務完成了
//   milestone_achieved  → 里程碑達成
// ─────────────────────────────────────────────────────────
model Notification {
  id           Int              @id @default(autoincrement())
  recipientId  Int              @map("recipient_id")  // 通知接收者
  type         NotificationType                        // 通知類型
  title        String           @db.VarChar(255)      // 通知標題（簡短）
  message      String           @db.Text              // 通知內容（詳細）
  isRead       Boolean          @default(false) @map("is_read")
  readAt       DateTime?        @map("read_at")
  /// 通知來源的資源類型：'task' | 'project' | 'comment'
  resourceType String?          @map("resource_type") @db.VarChar(50)
  resourceId   Int?             @map("resource_id")   // 點擊通知要跳轉到的資源 ID
  createdAt    DateTime         @default(now()) @map("created_at")
  deletedAt    DateTime?        @map("deleted_at")    // 軟刪除時間（非 null 表示已刪除）

  recipient User @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([isRead])       // 常用：查詢未讀通知
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  task_assigned        // 被指派任務
  deadline_approaching // 截止日期快到了
  task_overdue         // 任務已逾期
  mentioned            // 在評論中被@提及
  comment_added        // 你的任務有新評論
  task_completed       // 你建立的任務完成了
  milestone_achieved   // 里程碑達成
  system_digest        // 定期摘要報告
  automation_rule      // 自動化規則觸發的通知
}

// ── 表格 13：activity_logs（任務變更歷史）───────────────────
//
// 記錄任務的所有變更，讓使用者可以看到「誰在什麼時候改了什麼」
//
// 例子：
//   action: 'status_changed'
//   oldValue: { "status": "todo" }
//   newValue: { "status": "in_progress" }
//
// 為什麼用 JSONB？
//   不同的操作（status_changed、priority_changed、assigned 等）
//   有不同的欄位格式，用 JSONB 最靈活
//   PostgreSQL 的 JSONB 可以做索引和查詢，比 TEXT 好很多
// ─────────────────────────────────────────────────────────
model ActivityLog {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  userId    Int      @map("user_id")  // 誰做了這個動作
  /// 動作類型：created | status_changed | priority_changed |
  ///          assigned | commented | file_uploaded | due_date_changed | deleted
  action    String   @db.VarChar(50)
  /// 變更前的值（JSONB），例如 {"status": "todo"}
  /// 建立時沒有舊值，所以可以是 null
  oldValue  Json?    @map("old_value")
  /// 變更後的值（JSONB），例如 {"status": "in_progress"}
  newValue  Json?    @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ════════════════════════════════════════════════════════════
// OAuth 整合：Microsoft 365 Delegated Permissions Token 管理
// ════════════════════════════════════════════════════════════
//
// 為什麼要加密儲存 Token？
//   - Access Token 短期有效（1 小時），洩露影響有限
//   - Refresh Token 長期有效（最長 90 天），必須加密保護
//   - 演算法：AES-256-GCM（帶 Auth Tag，防止篡改）
//   - 加密 Key：OAUTH_TOKEN_ENCRYPTION_KEY 環境變數（64 hex chars = 32 bytes）
//
// Token 生命週期：
//   Authorization Code → Access Token (1h) + Refresh Token (90d)
//   Access Token 到期 → 用 Refresh Token 自動更新
//   Refresh Token 失效 → isActive=false，提示用戶重新授權
//
// 與 Client Credentials Flow 並存：
//   OAuthToken 存在且 isActive=true  → 用 Delegated（代表用戶）
//   OAuthToken 不存在或 isActive=false → Fallback 到 Application（系統信箱）
// ─────────────────────────────────────────────────────────

model OAuthToken {
  id              Int       @id @default(autoincrement())
  /// 一個用戶只能連結一個 Microsoft 帳號（unique 確保）
  userId          Int       @unique @map("user_id")
  provider        String    @default("microsoft") @db.VarChar(50)

  // ── 加密儲存的 Tokens（格式：base64(iv):base64(ciphertext):base64(authTag)）
  accessToken     String    @map("access_token")  @db.Text  // 短期 Token（1 小時），仍加密（防 DB 洩露）
  refreshToken    String    @map("refresh_token") @db.Text  // 長期 Token（90 天），AES-256-GCM 加密
  idToken         String?   @map("id_token")      @db.Text  // OpenID Connect ID Token（含用戶基本資訊）

  // ── Token 元資料 ──────────────────────────────────────
  /// 已授權的 Scopes，空格分隔，例如 "openid Mail.Send Calendars.ReadWrite"
  scopes          String    @db.Text
  expiresAt       DateTime  @map("expires_at")             // Access Token 到期時間
  tenantId        String?   @map("tenant_id") @db.VarChar(100) // Azure AD 租用戶 ID

  // ── Microsoft 帳號資訊 ────────────────────────────────
  microsoftUserId String?   @map("microsoft_user_id") @db.VarChar(200) // MS Graph 用戶 OID（物件識別碼）
  microsoftEmail  String?   @map("microsoft_email")   @db.VarChar(255) // 對應的公司 Email

  // ── 狀態管理 ──────────────────────────────────────────
  isActive        Boolean   @default(true) @map("is_active")
  revokedAt       DateTime? @map("revoked_at")             // 用戶主動撤銷時記錄
  lastRefreshedAt DateTime? @map("last_refreshed_at")      // 最後一次 Token 更新時間

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([expiresAt])   // 排程 Token 更新時使用
  @@map("oauth_tokens")
}

// ════════════════════════════════════════════════════════════
// Phase AI：自主代理決策記錄
// ════════════════════════════════════════════════════════════

// ── AI 決策記錄（包含完整 Chain of Thought）──────────────────
//
// 每一個 AI 自主決策都記錄在此：
//   - Observe：收集的原始資料
//   - Reason ：AI 的推理過程（CoT）
//   - Plan   ：計劃執行的動作
//   - Act    ：實際執行的動作（含影響範圍）
//   - Reflect：反思與學習
//
// 回滾機制：
//   snapshotData 儲存執行前的快照
//   一鍵還原只需要 status = 'rolled_back' + 從 snapshotData 還原
//
// 審核流程（Human-in-the-Loop）：
//   riskLevel 1 → AI 自動執行
//   riskLevel 2 → 建議人類批准（approvedById 填入後執行）
//   riskLevel 3 → 必須人類審查修改
//   riskLevel 4 → 人類主導，AI 輔助
// ─────────────────────────────────────────────────────────
model AiDecision {
  id            Int              @id @default(autoincrement())
  sessionId     String           @map("session_id") @db.VarChar(100) // Agent 執行 session UUID
  agentType     String           @map("agent_type") @db.VarChar(50)  // scheduler|risk|communication|quality
  decisionType  String           @map("decision_type") @db.VarChar(100) // auto_firefight|resource_balance|...
  projectId     Int?             @map("project_id")  // 關聯專案（可選）
  taskId        Int?             @map("task_id")      // 關聯任務（可選）

  // ── ReAct 推理鏈（Chain of Thought）──────────────────────
  observations  Json             // Observe：收集的資料快照（任務狀態、工時等）
  reasoning     String           @db.Text  // Reason：GPT-4 推理過程（完整 CoT 文字）
  plan          Json             // Plan：計劃執行的動作列表
  actions       Json             @default("[]") // Act：實際執行的動作結果
  reflection    String?          @db.Text  // Reflect：反思（決策效果、改進建議）

  // ── 執行狀態 ──────────────────────────────────────────────
  status        AiDecisionStatus @default(pending)
  riskLevel     Int              @map("risk_level") @default(1) // 1~4

  // ── 回滾支援 ──────────────────────────────────────────────
  snapshotData  Json?            @map("snapshot_data")  // 執行前狀態快照（用於回滾）
  rolledBackAt  DateTime?        @map("rolled_back_at")
  rolledBackBy  Int?             @map("rolled_back_by") // 誰執行回滾

  // ── 人類審核 ──────────────────────────────────────────────
  approvedById  Int?             @map("approved_by_id")
  approvedAt    DateTime?        @map("approved_at")
  rejectedAt    DateTime?        @map("rejected_at")
  rejectionNote String?          @map("rejection_note") @db.Text

  // ── 效果追蹤（強化學習用）────────────────────────────────
  humanAdopted  Boolean?         @map("human_adopted")  // 人類是否採納此決策
  outcomeScore  Int?             @map("outcome_score")  // 結果評分 0-100（事後評估）
  outcomeNote   String?          @map("outcome_note") @db.Text

  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  // ── 關聯 ──────────────────────────────────────────────────
  logs          AiAgentLog[]     // 每個決策對應多條工具呼叫日誌
  project       Project?         @relation(fields: [projectId],  references: [id], onDelete: SetNull)
  task          Task?            @relation(fields: [taskId],     references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([agentType])
  @@index([decisionType])
  @@index([status])
  @@index([projectId])
  @@index([taskId])
  @@index([createdAt])
  @@map("ai_decisions")
}

enum AiDecisionStatus {
  pending      // 等待執行
  staging      // 已寫入 Staging，等待人類批准
  approved     // 已批准，準備執行
  executing    // 執行中
  completed    // 執行完成
  rejected     // 被拒絕（人類否決）
  rolled_back  // 已回滾（人類發現問題）
  failed       // 執行失敗（系統錯誤）
}

// ── AI 代理執行日誌（細粒度操作記錄）────────────────────────
//
// 每個 AiDecision 對應多個 AiAgentLog（每次 tool call 一條記錄）
// 讓人類清楚看到 AI 做了哪些原子操作
// ─────────────────────────────────────────────────────────
model AiAgentLog {
  id           Int        @id @default(autoincrement())
  decisionId   Int        @map("decision_id")
  toolName     String     @map("tool_name") @db.VarChar(100) // 呼叫的 MCP tool 名稱
  toolInput    Json       @map("tool_input")   // 傳入的參數
  toolOutput   Json?      @map("tool_output")  // 回傳結果
  success      Boolean    @default(true)
  errorMessage String?    @map("error_message") @db.Text
  executedAt   DateTime   @default(now()) @map("executed_at")
  durationMs   Int?       @map("duration_ms")  // 執行時間（毫秒）

  decision     AiDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([toolName])
  @@index([executedAt])
  @@map("ai_agent_logs")
}

// ════════════════════════════════════════════════════════════
// Phase 4：AI 模型設定（OpenAI-Compatible API 設定）
// ════════════════════════════════════════════════════════════

// ── AI 模型設定（支援 OpenAI / Azure / Ollama / LM Studio / 自訂）────
//
// 設計目標：
//   - 讓系統管理員透過 UI 設定 AI 模型，不需要修改 .env 再重啟
//   - 支援任何 OpenAI-Compatible REST API（本地或雲端）
//   - API Key 可為空（本地模型如 Ollama 不需要 Key）
//   - 區分「複雜推理模型」與「輕量生成模型」，分別優化成本與品質
//
// 優先順序：資料庫設定 > 環境變數（ENV）
//   有資料庫設定且 isActive=true → 使用資料庫設定
//   否則 → 回退到 OPENAI_API_KEY 等環境變數
//
// Provider 預設：
//   openai    → https://api.openai.com/v1
//   azure     → https://{resource}.openai.azure.com/openai/deployments/{deployment}
//   ollama    → http://localhost:11434/v1
//   lm_studio → http://localhost:1234/v1
//   groq      → https://api.groq.com/openai/v1
//   custom    → 使用者自行輸入
// ─────────────────────────────────────────────────────────
// ════════════════════════════════════════════════════════════
// Phase 5 新增模型：OKR 目標管理
// ════════════════════════════════════════════════════════════

// ── Goal（Objective）────────────────────────────────────────
//
// 取代原本的 /tmp/pmis-goals-{companyId}.json 輕量儲存
// 支援父子目標階層（parentId 自我關聯），刪除父目標時子目標
// 的 parentId 設為 NULL（升格為頂層目標，不連鎖刪除）
// ────────────────────────────────────────────────────────────
model Goal {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")

  title       String   @db.VarChar(500)
  description String?  @db.Text
  quarter     String   @default("Q1") @db.VarChar(10)   // Q1 ~ Q4
  year        Int      @default(2024)
  status      String   @default("active") @db.VarChar(50) // active|completed|cancelled|on_hold
  owner       String?  @db.VarChar(255)                  // 負責人（文字，非 FK）

  // 父子目標自我關聯（策略地圖階層）
  parentId    Int?     @map("parent_id")
  parent      Goal?    @relation("GoalParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    Goal[]   @relation("GoalParent")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  keyResults KeyResult[]

  @@index([companyId])
  @@index([parentId])
  @@index([companyId, status])
  @@index([companyId, quarter, year])
  @@map("goals")
}

// ── KeyResult（關鍵結果）────────────────────────────────────
//
// 每個 Goal 可包含多個 KR，刪除 Goal 時 KR 一併刪除（Cascade）
// ────────────────────────────────────────────────────────────
model KeyResult {
  id           Int      @id @default(autoincrement())
  goalId       Int      @map("goal_id")

  title        String   @db.VarChar(500)
  unit         String   @default("") @db.VarChar(50)
  targetValue  Float    @default(0)  @map("target_value")
  currentValue Float    @default(0)  @map("current_value")
  status       String   @default("in_progress") @db.VarChar(50) // in_progress|done|at_risk|not_started
  position     Int      @default(0)                               // 排序用

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("key_results")
}

// ════════════════════════════════════════════════════════════

model AiModelConfig {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")

  // ── Provider 識別 ────────────────────────────────────────
  /// 提供者識別符：openai|azure|ollama|lm_studio|groq|custom
  provider    String   @default("openai") @db.VarChar(50)

  // ── 連線設定 ─────────────────────────────────────────────
  /// OpenAI-Compatible API 基底 URL，例如 https://api.openai.com/v1
  baseUrl     String   @default("https://api.openai.com/v1") @map("base_url") @db.VarChar(500)
  /// API 金鑰（本地模型可為空；儲存時請注意 DB 安全）
  apiKey      String?  @map("api_key") @db.Text

  // ── 模型選擇 ─────────────────────────────────────────────
  /// 複雜推理模型（任務拆解、風險分析）：需要最高智能
  modelHeavy  String   @default("gpt-4o") @map("model_heavy") @db.VarChar(100)
  /// 輕量生成模型（週報、摘要）：優化速度與成本
  modelLight  String   @default("gpt-4o-mini") @map("model_light") @db.VarChar(100)

  // ── 推理參數 ─────────────────────────────────────────────
  maxTokens   Int      @default(2000) @map("max_tokens")
  temperature Float    @default(0.3)

  // ── 狀態 ─────────────────────────────────────────────────
  isActive    Boolean  @default(true) @map("is_active")

  // ── 連線測試記錄 ─────────────────────────────────────────
  lastTestedAt DateTime? @map("last_tested_at")
  /// 最後一次連線測試的結果，例如 "success:gpt-4o" 或 "error:Connection refused"
  testResult   String?   @map("test_result") @db.VarChar(200)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isActive])
  @@map("ai_model_configs")
}

// ════════════════════════════════════════════════════════════
// Phase 6：工作流程 & 表單管理（/tmp JSON → PostgreSQL）
// ════════════════════════════════════════════════════════════

/// 工作流程定義（節點圖 + 觸發規則）
model Workflow {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  name      String   @db.VarChar(255)
  /// 流程節點陣列，如 [{id, label, color, count, desc}]
  nodes     Json     @default("[]")
  /// 觸發規則陣列，如 [{trigger, action, enabled}]
  rules     Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("workflows")
}

/// 公司內部表單（需求提交、Bug 回報等）
model Form {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  name        String    @db.VarChar(255)
  description String    @default("") @db.Text
  /// active | inactive
  status      String    @default("active") @db.VarChar(20)
  /// 欄位定義陣列，如 [{id, type, label, required, options, placeholder, order}]
  fields      Json      @default("[]")
  /// 累計提交次數
  submissions Int       @default(0)
  lastSubmit  DateTime? @map("last_submit")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  formSubmissions FormSubmission[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("forms")
}

/// 表單提交紀錄
model FormSubmission {
  id          Int      @id @default(autoincrement())
  formId      Int      @map("form_id")
  companyId   Int      @map("company_id")
  /// 提交資料 JSON，如 { fieldId: value, ... }
  data        Json     @default("{}")
  submittedBy String?  @default("") @map("submitted_by") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  form    Form    @relation(fields: [formId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([companyId])
  @@map("form_submissions")
}

// ════════════════════════════════════════════════════════════
// 手動工時記錄（每日時間表）
// 前端「工時管理」頁面使用，以文字記錄專案/任務名稱
// 不同於 time_entries（計時器啟停），這是手動填入 hours 的日報表
// ════════════════════════════════════════════════════════════
model WorkTimeLog {
  id        String   @id @default(cuid())
  companyId Int      @map("company_id")
  userId    Int      @map("user_id")
  date      String   @db.VarChar(10)   // YYYY-MM-DD
  project   String   @db.VarChar(255)  // 專案名稱（自由文字）
  task      String   @db.VarChar(255)  // 任務名稱（自由文字）
  hours     Float                      // 工時（小時，允許小數）
  note      String   @default("") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([date])
  @@index([companyId, date])
  @@map("work_time_logs")
}

// ════════════════════════════════════════════════════════════
// AI 建議決策（前端 AI 助理頁面）
// 比 AiDecision（ReAct Agent 用）簡單，存放人工可審核的建議清單
// ════════════════════════════════════════════════════════════
model AiSuggestion {
  id          String    @id @default(cuid())
  companyId   Int       @map("company_id")
  type        String    @db.VarChar(100)   // 風險預警|自動指派|截止日建議|效率洞察
  title       String    @db.VarChar(255)
  scope       String    @db.VarChar(255)   // 適用範圍（專案名稱或「全局」）
  confidence  Int       @default(0)        // 信心度 0~100
  detail      String    @default("") @db.Text
  status      String    @default("pending") @db.VarChar(20) // pending|approved|rejected
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@map("ai_suggestions")
}

// ════════════════════════════════════════════════════════════
// 專案組合（Portfolio）
// ════════════════════════════════════════════════════════════

model Portfolio {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  name        String    @db.VarChar(255)
  description String    @default("")
  color       String    @default("#3b82f6") @db.VarChar(30)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects PortfolioProject[]

  @@index([companyId])
  @@map("portfolios")
}

model PortfolioProject {
  id             Int      @id @default(autoincrement())
  portfolioId    Int      @map("portfolio_id")
  projectId      Int      @map("project_id")
  notes          String   @default("")
  healthOverride String?  @map("health_override") @db.VarChar(20) // 手動覆寫健康度（null = 自動計算）
  createdAt      DateTime @default(now()) @map("created_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId],   references: [id], onDelete: Cascade)

  @@unique([portfolioId, projectId])
  @@index([portfolioId])
  @@index([projectId])
  @@map("portfolio_projects")
}
