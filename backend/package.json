{
  "name": "pmis-backend",
  "version": "1.0.0",
  "description": "xCloudPMIS 後端 API 服務",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:generate": "prisma generate",
