# ============================================================
# xCloudPMIS 環境變數範本
# 使用方式：複製此檔案為 .env，再修改裡面的值
# 指令：cp .env.example .env
# ============================================================

# ── PostgreSQL 資料庫設定（Azure Database for PostgreSQL）──
DB_HOST=pmis-db-725.postgres.database.azure.com
DB_USER=pmisadmin
DB_PASSWORD=hnmxt2DpJiaqz0YP!1aA
DB_NAME=pmis_db
# Prisma ORM 連線字串（Azure PostgreSQL，sslmode=require）
DATABASE_URL=postgresql://pmisadmin:hnmxt2DpJiaqz0YP!1aA@pmis-db-725.postgres.database.azure.com/pmis_db?sslmode=require

# ── pgAdmin 管理介面設定 ───────────────────────────────────
PGADMIN_EMAIL=admin@pmis.com
PGADMIN_PASSWORD=admin123         # ⚠️ 正式環境請改為強密碼

# ── Redis 快取設定（Azure Cache for Redis）─────────────────
REDIS_HOST=pmis-redis-356.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=lKd9nsp7w89q86mBK9SaDNkXMb77gVQifAzCaGj6we4=
REDIS_TLS=true

# ── JWT 認證金鑰 ───────────────────────────────────────────
# 用途：加密用戶登入 Token，必須是隨機的長字串
# 產生方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=zmCrlITJ84wgaLVF1DAMkdZ7vEp9u3Nh

# ── 前端 URL（郵件連結用）──────────────────────────────────
FRONTEND_URL=https://pmis-frontend.yellowocean-6b8afa53.eastasia.azurecontainerapps.io

# ════════════════════════════════════════════════════════════
# OAuth 2.0 第三方登入設定
# 設定後可讓使用者用 Microsoft / Google / GitHub 帳號直接登入
# OAuth callback 基礎 URL（必須與第三方平台填寫的 Redirect URI 一致）
# ════════════════════════════════════════════════════════════
OAUTH_CALLBACK_BASE=http://localhost:3838
# OAuth 自動建立帳號（true = 允許新 Email 透過 OAuth 自動註冊）
OAUTH_ALLOW_REGISTRATION=true

# ── Microsoft OAuth 2.0（Azure AD / Entra ID）─────────────
# 申請方式：https://portal.azure.com → 應用程式註冊
# Redirect URI 填入：http://localhost:3838/api/auth/microsoft/callback
# 所需權限 Scopes：openid, profile, email, User.Read
MICROSOFT_CLIENT_ID=0d4d2876-e3ec-449b-8292-7ea4929ab313
MICROSOFT_CLIENT_SECRET=K.l8Q~9CzwNQY_UotY28SZS3rs5z9cluuGKWGdxd
MICROSOFT_TENANT_ID=5b465551-393e-4821-a2b0-5547f20ab78f

# ── Microsoft Delegated Token（設定頁整合服務用）───────────
# 與上方共用同一個 Azure App Registration
# Redirect URI 需另外加入：http://localhost:3838/auth/microsoft/callback
# 所需權限：Mail.ReadWrite, Mail.Send, Calendars.ReadWrite,
#           OnlineMeetings.ReadWrite, Tasks.ReadWrite, offline_access
OAUTH_MICROSOFT_CLIENT_ID=0d4d2876-e3ec-449b-8292-7ea4929ab313
OAUTH_MICROSOFT_CLIENT_SECRET=K.l8Q~9CzwNQY_UotY28SZS3rs5z9cluuGKWGdxd
OAUTH_MICROSOFT_TENANT_ID=5b465551-393e-4821-a2b0-5547f20ab78f

# OAuth Token 加密金鑰（AES-256-GCM，64 hex chars = 32 bytes）
# 生成指令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_TOKEN_ENCRYPTION_KEY=225f7b6b9f250a1715c72271b4f088ec8432e26b9f767e083b134190cc84721f

# ── Google OAuth 2.0 ──────────────────────────────────────
# 申請方式：https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI 填入：http://localhost:3838/api/auth/google/callback
# 所需 Scopes：openid, email, profile
GOOGLE_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret-here

# ── GitHub OAuth App ──────────────────────────────────────
# 申請方式：https://github.com/settings/developers → New OAuth App
# Homepage URL：http://localhost:3838
# Callback URL：http://localhost:3838/api/auth/github/callback
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# ════════════════════════════════════════════════════════════
# Azure Communication Services (ACS) 郵件設定
# Azure Portal → Communication Services → 鍵
# ════════════════════════════════════════════════════════════

# ACS 連線字串
# Azure Portal → Communication Services → 您的資源 → 鍵 → 連接字串
ACS_CONNECTION_STRING=endpoint=https://comm-billing-system.unitedstates.communication.azure.com/;accesskey=9DZZXEsHokT52KYl4iv9jNOiy1vgQM0gEVRzlAJ94krCw3JryRiXJQQJ99BKACULyCppiAl7AAAAAZCStObX

# 寄件人信箱（需在 ACS 已驗證的網域中）
ACS_SENDER_EMAIL=pmis@bi.cloudinfo.com.tw

# 寄件人顯示名稱
ACS_SENDER_NAME=xCloudPMIS

# ── 郵件安全設定（選填）─────────────────────────────────────
# 允許發信的目標網域白名單（逗號分隔）
# 留空 = 不限制（開發環境）；正式環境建議填入，例如：yourcompany.com
EMAIL_ALLOWED_DOMAINS=

# 批次發送每封間隔毫秒（預設 300）
EMAIL_BATCH_DELAY_MS=300

# ════════════════════════════════════════════════════════════
# 排程設定（第三階段使用）
# ════════════════════════════════════════════════════════════
# 時區（台灣標準時間）
TZ=Asia/Taipei

# 每日到期提醒排程（cron 格式，週一到週五早上 9:00）
CRON_DAILY_REMINDER=0 9 * * 1-5

# 週報排程（每週五下午 5:00）
CRON_WEEKLY_REPORT=0 17 * * 5

# 幾天前開始提醒（預設 3 天）
REMINDER_DAYS_BEFORE=3

# 排程查詢用的公司 ID
SCHEDULER_COMPANY_ID=1

# ════════════════════════════════════════════════════════════
# AI Agent 設定（OpenAI GPT-4 整合）
# 取得 API 金鑰：https://platform.openai.com/api-keys
# ════════════════════════════════════════════════════════════

# OpenAI API 金鑰（必填，格式：sk-...）
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI 組織 ID（選填，有多個組織時填入）
# 格式：org-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ORG_ID=

# ── AI 行為設定 ─────────────────────────────────────────────
# 回應語言（預設：zh-TW 繁體中文）
# 選項：zh-TW（繁體中文）、zh-CN（簡體中文）、en-US（英文）
AI_LANGUAGE=zh-TW（繁體中文）

# 公司名稱（植入 AI system prompt，讓 AI 了解服務的對象）
AI_COMPANY_NAME=xCloudPMIS

# 單次呼叫最大 token 數（預設 2000，提高可得到更詳細的分析）
# ⚠️ 注意：提高此值會增加 API 費用
AI_MAX_TOKENS=2000

# ── AI 風險掃描排程（背景自動執行）────────────────────────
# 每日凌晨 3:00 自動執行全公司 AI 風險掃描
CRON_AI_RISK_SCAN=0 3 * * *

# 風險分數閾值（超過此分數才建立「風險管理任務」）
# 範圍：0 ~ 100，預設 70（高風險以上）
AI_RISK_THRESHOLD=70

# 風險任務的預設指派人 ID（PM 或主管的 user ID）
AI_RISK_TASK_DEFAULT_ASSIGNEE=1
