# ============================================================
# xCloudPMIS 環境變數範本
# 使用方式：複製此檔案為 .env，再修改裡面的值
# 指令：cp .env.example .env
# ============================================================

# ── PostgreSQL 資料庫設定 ──────────────────────────────────
POSTGRES_DB=pmis_db
POSTGRES_USER=pmis_user
POSTGRES_PASSWORD=pmis_password   # ⚠️ 正式環境請改為強密碼

# ── pgAdmin 管理介面設定 ───────────────────────────────────
PGADMIN_EMAIL=admin@pmis.com
PGADMIN_PASSWORD=admin123         # ⚠️ 正式環境請改為強密碼

# ── Redis 快取設定 ─────────────────────────────────────────
REDIS_PASSWORD=redis123           # ⚠️ 正式環境請改為強密碼

# ── JWT 認證金鑰 ───────────────────────────────────────────
# 用途：加密用戶登入 Token，必須是隨機的長字串
# 產生方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ── 前端 URL（郵件連結用）──────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ════════════════════════════════════════════════════════════
# Microsoft 365 / Exchange Online 郵件設定
# 取得方式：請參閱 docs/EXCHANGE_SETUP.md
# ════════════════════════════════════════════════════════════

# 應用程式 (用戶端) 識別碼
# Azure Portal → 應用程式註冊 → 您的應用程式 → 概觀
O365_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 用戶端密碼「值」（不是 ID！建立後只顯示一次，請立即複製）
# Azure Portal → 應用程式註冊 → 憑證和祕密 → 用戶端祕密 → 值
O365_CLIENT_SECRET=your-client-secret-VALUE-here

# 目錄 (租用戶) 識別碼
# Azure Portal → Microsoft Entra ID → 概觀 → 租用戶識別碼
O365_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 發件人信箱（需在此 Exchange 組織中存在，建議用共享信箱）
O365_SENDER_EMAIL=noreply@yourcompany.com

# ── 郵件安全設定（選填）─────────────────────────────────────
# 允許發信的目標網域白名單（逗號分隔）
# 留空 = 不限制（開發環境）；正式環境建議填入，例如：yourcompany.com
EMAIL_ALLOWED_DOMAINS=

# 批次發送每封間隔毫秒（預設 300，避免 Graph API 速率限制）
EMAIL_BATCH_DELAY_MS=300

# ════════════════════════════════════════════════════════════
# 排程設定（第三階段使用）
# ════════════════════════════════════════════════════════════
# 時區（台灣標準時間）
TZ=Asia/Taipei

# 每日到期提醒排程（cron 格式，週一到週五早上 9:00）
CRON_DAILY_REMINDER=0 9 * * 1-5

# 週報排程（每週五下午 5:00）
CRON_WEEKLY_REPORT=0 17 * * 5

# 幾天前開始提醒（預設 3 天）
REMINDER_DAYS_BEFORE=3

# 排程查詢用的公司 ID
SCHEDULER_COMPANY_ID=2
