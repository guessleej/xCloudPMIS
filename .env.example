# ============================================================
# xCloudPMIS 環境變數範本
# 使用方式：複製此檔案為 .env，再修改裡面的值
# 指令：cp .env.example .env
# ============================================================

# ── PostgreSQL 資料庫設定 ──────────────────────────────────
POSTGRES_DB=pmis_db
POSTGRES_USER=pmis_user
POSTGRES_PASSWORD=pmis_password   # ⚠️ 正式環境請改為強密碼

# ── pgAdmin 管理介面設定 ───────────────────────────────────
PGADMIN_EMAIL=admin@pmis.com
PGADMIN_PASSWORD=admin123         # ⚠️ 正式環境請改為強密碼

# ── Redis 快取設定 ─────────────────────────────────────────
REDIS_PASSWORD=redis123           # ⚠️ 正式環境請改為強密碼

# ── JWT 認證金鑰 ───────────────────────────────────────────
# 用途：加密用戶登入 Token，必須是隨機的長字串
# 產生方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
